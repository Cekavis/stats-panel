{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stats Panel",
  "version": "0.2.23",
  "identifier": "com.cekav.statspanel",
  "build": {
    "beforeDevCommand": "npm run build:driver && npm run build:helper && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stats Panel",
        "label": "main",
        "width": 1280,
        "height": 2160,
        "minWidth": 320,
        "minHeight": 420,
        "decorations": false,
        "resizable": true,
        "center": true
      },
      {
        "title": "Stats Panel Settings",
        "label": "settings",
        "url": "index.html?view=settings",
        "width": 520,
        "height": 720,
        "minWidth": 420,
        "minHeight": 480,
        "decorations": true,
        "resizable": true,
        "center": true,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "binaries/PawnIO_setup.exe"
    ],
    "externalBin": [
      "binaries/stats-sensor-helper"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
